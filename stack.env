BOOKSTACK_DB_PASS=ArbitraryString
BOOKSTACK_ROOT_PASS=DifferentArbitraryString
IPA_ADMIN_PASSWORD=Sitemap-Ratios-Combinations-Ping-1

# Authentik
# Generate AUTHENTIK_SECRET_KEY with: openssl rand -base64 36
AUTHENTIK_SECRET_KEY=CHANGEME_openssl_rand_base64_36
AUTHENTIK_POSTGRESQL__PASSWORD=CHANGEME_db_password
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__DB=authentik
# Optional email config (for password reset)
#AUTHENTIK_EMAIL__HOST=smtp.example.com
#AUTHENTIK_EMAIL__PORT=587
#AUTHENTIK_EMAIL__USERNAME=
#AUTHENTIK_EMAIL__PASSWORD=
#AUTHENTIK_EMAIL__USE_TLS=true
#AUTHENTIK_EMAIL__USE_SSL=false
#AUTHENTIK_EMAIL__FROM=authentik@hacker-haus.org

# BookStack OIDC (set after creating Authentik provider)
BOOKSTACK_OIDC_CLIENT_ID=CHANGEME
BOOKSTACK_OIDC_CLIENT_SECRET=CHANGEME

# Joplin SSO (set after creating Authentik provider)
JOPLIN_SSO_CLIENT_ID=CHANGEME
JOPLIN_SSO_CLIENT_SECRET=CHANGEME